# Vector configuration
# Generated by Ansible

data_dir: {{ vector_data_dir }}

sources:
  file_source:
    type: file
    include:
      - /var/log/messages
      - /var/log/secure
    read_from: beginning
    ignore_older_secs: 600

transforms:
  remap_transform:
    type: remap
    inputs: ["file_source"]
    source: |
      . = parse_syslog!(string!(.message))
      .host = get_hostname!()

sinks:
  clickhouse_sink:
    type: clickhouse
    inputs: ["remap_transform"]
    endpoint: "http://{{ clickhouse_host }}:{{ clickhouse_port }}"
    database: "{{ clickhouse_database }}"
    table: "{{ clickhouse_table }}"
    compression: gzip
    healthcheck: false